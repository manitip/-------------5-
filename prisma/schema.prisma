generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model PrayerRequest {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category   String
  urgency    String   @default("usual") // usual | urgent
  forWhom    String   @default("self")  // self | other

  message    String
  name       String?
  email      String?
  phone      String
  city       String   @default("izhevsk") // izhevsk | other
  meetingFormat String? // home_visit | self_visit | online
  address    String?

  status     String   @default("new")   // new | praying | done
  ipHash     String?                    // не храним IP напрямую

  deletedAt  DateTime?
}
